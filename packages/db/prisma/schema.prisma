generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TRAINER
  CLIENT
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           UserRole        @default(CLIENT)
  active         Boolean         @default(true)
  trainerProfile TrainerProfile?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TrainerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String
  professionalTitle String
  shortBio          String?
  biography         String?
  avatarUrl         String?
  phone             String?
  location          String?
  specialization    String?
  yearsExperience   Int      @default(0)
  clientsCoached    Int      @default(0)
  published         Boolean  @default(false)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  description String
  year        Int?
  category    String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

model Certification {
  id            String    @id @default(cuid())
  title         String
  issuer        String
  description   String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  credentialUrl String?
  sortOrder     Int       @default(0)
  published     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published, sortOrder])
}

model Program {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  imageUrl    String?
  duration    String?
  format      String?
  benefits    String[] @default([])
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  altText     String
  imageUrl    String
  category    String?
  description String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  avatarUrl String?
  role      String?
  quote     String
  result    String?
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archived, read, createdAt])
  @@index([email])
}
