{
  "name": "sumifitness",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "npm run db:generate && npm run build --workspace @sumifitness/db && npm run dev --workspace @sumifitness/api",
    "build": "npm run db:generate && next build && npm run build --workspace @sumifitness/db && npm run build --workspace @sumifitness/api",
    "start": "next start",
    "start:api": "npm run start --workspace @sumifitness/api",
    "lint": "eslint .",
    "typecheck": "npm run db:generate && next typegen && tsc --noEmit && npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate --workspace @sumifitness/db",
    "db:validate": "npm run validate --workspace @sumifitness/db",
    "db:migrate": "npm run migrate:dev --workspace @sumifitness/db",
    "db:studio": "npm run studio --workspace @sumifitness/db"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.42.0",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.80.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3"
  }
}
